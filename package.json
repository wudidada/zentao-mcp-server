{
  "name": "@wudidada/zentao-mcp-server",
  "version": "1.0.1",
  "description": "ZenTao API V1.0 MCP Server（禅道 MCP：登录、Bug 查询/解决/激活等）",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "zentao-mcp-server": "cli.mjs"
  },
  "files": [
    "cli.mjs",
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepublishOnly": "npm run build",
    "dev": "tsx src/index.ts",
    "start:stdio": "tsx src/server/stdio.ts",
    "start:http": "tsx src/server/http.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "zentao",
    "禅道",
    "bug"
  ],
  "author": "",
  "license": "ISC",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wudidada/zentao-mcp-server.git"
  },
  "bugs": {
    "url": "https://github.com/wudidada/zentao-mcp-server/issues"
  },
  "homepage": "https://github.com/wudidada/zentao-mcp-server#readme",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "axios": "^1.15.0",
    "dotenv": "^17.4.2",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "nock": "^14.0.12",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  }
}
